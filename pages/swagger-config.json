    "/api/tools/ssweb": {
      "get": {
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "URL dari halaman yang ingin di-screenshot"
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mengambil screenshot",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Parameter 'url' tidak diberikan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean" },
                    "creator": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          },
          "405": {
            "description": "Metode tidak diizinkan"
          },
          "500": {
            "description": "Kesalahan internal server",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean" },
                    "creator": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/base64": {
  "get": {
    "tags": ["Tools"],
    "parameters": [
      {
        "name": "input",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "required": true,
        "description": "Teks yang akan dikonversi ke Base64 atau Base64 yang akan dikonversi kembali ke teks"
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "boolean" },
                "creator": { "type": "string" },
                "input": { "type": "string" },
                "output": { "type": "string" }
              }
            }
          }
        }
      },
      "400": {
        "description": "Bad Request - Parameter 'input' tidak boleh kosong atau format Base64 tidak valid"
      },
      "401": {
        "description": "Unauthorized"
      },
      "500": {
        "description": "Internal Server Error"
      }
    }
  }
