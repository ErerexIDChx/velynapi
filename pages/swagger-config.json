          "description": "Valid Instagram URL (post, reel, tv, story)"
        }
      ],
      "security": [
        {
          "ApiKeyAuth": []
        }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "example": {
                "status": true,
                "creator": "VelynAPI",
                "data": {
                  "url": "result_url", 
                  "metadata": {
                    "source": "instagram",
                    "original_url": "url"
                  }
                }
              }
