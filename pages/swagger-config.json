    "/api/tools/Carbonfyv1": {
      "post": {
        "tags": ["Tools"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "default": "hallo wirr"
                  }
                },
