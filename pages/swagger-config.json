      "tags": ["Downloader"],
      "summary": "Instagram media data",
      "parameters": [
        {
          "name": "url",
          "in": "query",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uri",
            "example": "https://www.instagram.c///"
